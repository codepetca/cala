@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  body {
    @apply bg-white text-gray-900 dark:bg-gray-900 dark:text-gray-100;
  }
  
  /* Drag and drop styling */
  .drag-item.is-being-dragged {
    @apply shadow-2xl bg-white dark:bg-gray-900 opacity-100 transform rotate-2 scale-105;
    border: none !important;
    z-index: 9999;
  }
  
  .drag-item.is-dragged-over {
    @apply bg-blue-50 dark:bg-blue-900/20;
  }
}